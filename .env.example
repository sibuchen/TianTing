# ============================================================
# TianTing 环境变量配置模板
# 使用方法：cp .env.example .env，然后修改相关配置
# ============================================================

# ========================= Application =========================
# 应用名称
APP_NAME=TianTing
# 应用版本号
APP_VERSION=0.1.0
# 后端服务监听端口
APP_PORT=2811
# 调试模式（开发环境设为 true，生产环境必须设为 false）
DEBUG=false
# 运行环境：development（开发）/ production（生产）/ testing（测试）
ENVIRONMENT=production

# ========================= API =========================
# API V1 路由前缀
API_V1_PREFIX=/api/v1
# OpenAPI 规范地址（设为空则禁用）
OPENAPI_URL=/openapi.json
# Swagger UI 文档地址（设为空则禁用）
DOCS_URL=/docs
# ReDoc 文档地址（设为空则禁用）
REDOC_URL=/redoc

# ========================= CORS 跨域 =========================
# 允许的跨域来源列表，多个用逗号分隔
CORS_ORIGINS=["http://localhost:2424"]
# 是否允许携带凭证（Cookie 等）
CORS_ALLOW_CREDENTIALS=true
# 允许的 HTTP 方法，["*"] 表示全部允许
CORS_ALLOW_METHODS=["*"]
# 允许的请求头，["*"] 表示全部允许
CORS_ALLOW_HEADERS=["*"]

# ========================= Database（PostgreSQL） =========================
# 数据库连接串（格式：postgresql+asyncpg://用户名:密码@主机:端口/数据库名）
DATABASE_URL=postgresql+asyncpg://sibuchen:postgres-sibuchen-password@localhost:5432/tianting
# 连接池大小
DATABASE_POOL_SIZE=20
# 连接池最大溢出数（超出 pool_size 后最多再创建的连接数）
DATABASE_MAX_OVERFLOW=10
# 是否打印 SQL 语句（开发调试时可设为 true）
DATABASE_ECHO=false
# PostgreSQL 密码（生产环境务必修改！需与 DATABASE_URL 中的密码一致）
POSTGRES_PASSWORD=postgres-sibuchen-password

# ========================= Redis =========================
# Redis 密码（需与下面 URL 中的密码一致）
REDIS_PASSWORD=redis-sibuchen-password
# Redis 连接地址（格式：redis://:密码@主机:端口/数据库编号）
REDIS_URL=redis://:redis-sibuchen-password@localhost:6379/0
# Redis 最大连接数
REDIS_MAX_CONNECTIONS=50
# ARQ 任务队列使用的 Redis 连接地址（与主 Redis 使用不同数据库编号以隔离）
ARQ_REDIS_URL=redis://:redis-sibuchen-password@localhost:6379/1

# ========================= JWT 认证 =========================
# JWT 签名密钥（生产环境务必修改为随机长字符串！）
JWT_SECRET_KEY=your-secret-key-change-in-production
# JWT 加密算法
JWT_ALGORITHM=HS256
# Access Token 过期时间（分钟），默认 1440 分钟 = 24 小时
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Refresh Token 过期时间（天），默认 7 天
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 生产环境中， JWT_SECRET_KEY 必须使用随机生成的强密钥，不要使用默认值。以下是各平台的生成命令：
# | 平台 | 命令 |
# |------|------|
# | Linux / macOS | `openssl rand -hex 32` |
# | Windows (PowerShell) | `[Convert]::ToHexString((1..32 | ForEach-Object {Get-Random -Max 256}))` |

# ========================= Security =========================
# 用户密码最小长度
PASSWORD_MIN_LENGTH=8
# Bcrypt 哈希轮数（越大越安全但越慢，建议 12）
BCRYPT_ROUNDS=12
# API Key 加密密钥（必须为 32 字节，生产环境务必修改！）
ENCRYPTION_KEY=your-32-byte-encryption-key!
# Token 加密文件存储目录（留空则自动使用 ~/.tianting，Windows 为 %USERPROFILE%\.tianting, Docker 部署时设为 /home/tianting/.tianting（挂载到 Docker Volume））
TOKEN_STORE_DIR=

# 生产环境中， ENCRYPTION_KEY 必须使用随机生成的强密钥，不要使用默认值。以下是各平台的生成命令：
# | 平台 | 命令 |
# |------|------|
# | Linux / macOS | `openssl rand -base64 32` |
# | Windows (PowerShell) | `-join ((48..57)+(65..90)+(97..122) | Get-Random -Count 32 | % {[char]$_})` |


# ========================= File Upload =========================
# 上传文件存储目录
UPLOAD_DIR=/tmp/tianting/uploads
# 上传文件大小上限（字节），默认 52428800 = 50MB
MAX_UPLOAD_SIZE=52428800
# 允许上传的文件类型列表
ALLOWED_FILE_TYPES=["pdf","docx","txt","md"]

# ========================= Rate Limiting =========================
# 全局 API 限流（每分钟最大请求数）
RATE_LIMIT_PER_MINUTE=60
# 聊天接口限流（每分钟最大请求数）
CHAT_RATE_LIMIT_PER_MINUTE=30

# ========================= Cache TTL =========================
# 会话缓存过期时间（秒），默认 300 秒 = 5 分钟
CACHE_TTL_CONVERSATION=300
# 对话历史缓存过期时间（秒），默认 600 秒 = 10 分钟
CACHE_TTL_CHAT_HISTORY=600
# Agent 配置缓存过期时间（秒），默认 1800 秒 = 30 分钟
CACHE_TTL_AGENT_CONFIG=1800
# 对话历史缓存最大条数
CACHE_CHAT_HISTORY_MAX_LEN=50

# ========================= Qdrant 向量数据库 =========================
# 是否启用 Qdrant 向量数据库（启用后优先使用 Qdrant 做语义检索，pgvector 作为降级回退）
QDRANT_ENABLED=true
# Qdrant 服务地址（Docker 内部使用 qdrant:6333，本地开发使用 localhost:6333）
QDRANT_URL=http://localhost:6333
# Qdrant API Key（留空表示不使用认证）
QDRANT_API_KEY=qdrant-sibuchen-password
# Qdrant Collection 名称前缀
QDRANT_COLLECTION_PREFIX=tianting

# ========================= Neo4j 图数据库 =========================
# 是否启用 Neo4j 图数据库（启用后自动同步 Agent 关系、知识关联等图谱数据）
NEO4J_ENABLED=true
# Neo4j Bolt 连接地址（Docker 内部使用 bolt://neo4j:7687，本地开发使用 bolt://localhost:7687）
NEO4J_URI=bolt://localhost:7687
# Neo4j 用户名
NEO4J_USER=neo4j
# Neo4j 密码（生产环境务必修改！）
NEO4J_PASSWORD=neo4j-sibuchen-password

# ========================= MongoDB 日志存储 =========================
# 是否启用 MongoDB 日志存储（启用后 Agent 操作日志和对话事件写入 MongoDB，文件系统作为降级回退）
MONGODB_ENABLED=true
# MongoDB 密码（生产环境务必修改！）
MONGO_PASSWORD=mongo-sibuchen-password
# MongoDB 连接地址（Docker 内部使用 mongodb://mongodb:27017，本地开发使用 mongodb://localhost:27017）
MONGODB_URL=mongodb://sibuchen:mongo-sibuchen-password@localhost:27017/tianting?authSource=admin
# MongoDB 数据库名称
MONGODB_DB_NAME=tianting

# ========================= Snowflake 数据分析（云服务，需单独配置） =========================
# 是否启用 Snowflake 数据导出管道
SNOWFLAKE_ENABLED=false
# 数据导出目录（CSV 文件存放路径）
SNOWFLAKE_EXPORT_DIR=./data/exports

# ========================= LangGraph =========================
# LangGraph 检查点存储后端（目前仅支持 postgres）
LANGGRAPH_CHECKPOINTER=postgres

# ========================= 嵌入（Embedding）模型 =========================
# 嵌入模型 API 地址（使用 RAG 功能时必须配置，查看官网 地址 模板）
EMBED_MODEL_BASE_URL=https://integrate.api.nvidia.com/v1
# 嵌入模型 API Key（使用 RAG 功能时必须配置）
EMBED_MODEL_API_KEY=nvapi-sibuchen-free-api-key
# 嵌入模型名称（使用 RAG 功能时必须配置，默认 nvidia/nv-embed-v1，4096 维）
EMBED_MODEL_ID=nvidia/nv-embed-v1
# 嵌入模型向量维度（必须与模型实际输出维度一致，nvidia/nv-embed-v1 模型输出 4096 维）
# pgvector 0.8.0+ 支持最大 16000 维 HNSW 索引，请确保 pgvector 版本 ≥ 0.8.0
# 如需更换模型，请同步修改 database/init.sql 中的 vector(N) 和 COMMENT
EMBED_MODEL_DIMENSION=4096

# ========================= RAG 检索增强 =========================
# 文档分块大小（字符数）
CHUNK_SIZE=500
# 文档分块重叠字符数（相邻块之间的重叠区域，提高检索召回率）
CHUNK_OVERLAP=50
# 检索返回的最相关文档数量
RETRIEVAL_TOP_K=5

# ========================= Feishu IM 集成 =========================
# 是否启用飞书 IM 集成（不使用/使用飞书 可保持false/改为true）
FEISHU_ENABLED=false
# 飞书应用 App ID（飞书开放平台获取）
FEISHU_APP_ID=
# 飞书应用 App Secret（飞书开放平台获取）
FEISHU_APP_SECRET=
# 飞书事件订阅验证 Token（飞书开放平台获取）
FEISHU_VERIFICATION_TOKEN=
# 飞书事件订阅加密 Key（飞书开放平台获取）
FEISHU_ENCRYPT_KEY=
# 飞书事件接收模式：websocket（长连接，推荐）/ webhook（回调地址）
FEISHU_EVENT_MODE=websocket

# ========================= Docker 部署 =========================
# 网关端口（Docker 部署时 Nginx 监听端口，默认 3534，如需修改可设置其他端口如 80，8080）
GATEWAY_PORT=3534
